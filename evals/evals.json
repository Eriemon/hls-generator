{
  "version": 1,
  "title": "Erie HLS Generator Evaluation Corpus",
  "design_patterns": [
    "Tool Wrapper",
    "Generator",
    "Reviewer",
    "Inversion",
    "Pipeline"
  ],
  "cases": [
    {
      "id": "trigger-hls-vitis",
      "title": "HLS and Vitis trigger coverage",
      "with_skill_expected_pass": true,
      "without_skill_expected_pass": false,
      "without_skill_reason": "A baseline assistant is not guaranteed to bind to the repo-local HLS skill contract.",
      "required_files": ["SKILL.md"],
      "required_terms": [
        {
          "file": "SKILL.md",
          "terms": ["Vitis HLS", "high-level synthesis", "HLS debug", "csim/cosim"]
        }
      ]
    },
    {
      "id": "boundary-hls-only",
      "title": "HLS-only boundary stays explicit",
      "with_skill_expected_pass": true,
      "without_skill_expected_pass": false,
      "without_skill_reason": "A baseline prompt path does not inherit the repo's HLS-only boundary.",
      "required_files": ["SKILL.md", "references/hls-project-structure-patterns.md"],
      "required_terms": [
        {
          "file": "SKILL.md",
          "terms": ["Do not generate handwritten Verilog", "Do not modify files outside this repository"]
        },
        {
          "file": "references/hls-project-structure-patterns.md",
          "terms": ["host code generation", "package script generation"]
        }
      ]
    },
    {
      "id": "confidence-pytest-gate",
      "title": "Confidence loop includes pytest",
      "with_skill_expected_pass": true,
      "without_skill_expected_pass": false,
      "without_skill_reason": "A baseline evaluation does not assume repo-specific pytest gating.",
      "required_files": [
        "scripts/python/validation/confidence_loop.py",
        "scripts/python/remote/remote_vitis_acceptance.py"
      ],
      "required_terms": [
        {
          "file": "scripts/python/validation/confidence_loop.py",
          "terms": ["\"remote_pytest\"", "_run_remote_pytest", "_run_split_remote_pytest"]
        },
        {
          "file": "scripts/python/remote/remote_vitis_acceptance.py",
          "terms": ["python -m pytest -q tests", "_run_pytest_mode"]
        }
      ]
    },
    {
      "id": "route-contract-threadfpga",
      "title": "Remote route contract targets the active ThreadFPGA host",
      "with_skill_expected_pass": true,
      "without_skill_expected_pass": false,
      "without_skill_reason": "The baseline path does not know the AGENTS-managed route table.",
      "required_files": ["../../AGENTS.md", "scripts/python/validation/confidence_loop.py", "scripts/python/validation/confidence_remote.py"],
      "required_terms": [
        {
          "file": "../../AGENTS.md",
          "terms": ["`remote-hls-validation`: primary `server_6`", "U55C 硬件指纹证据"]
        },
        {
          "file": "scripts/python/validation/confidence_loop.py",
          "terms": ["route_contract", "_route_contract_gate"]
        },
        {
          "file": "scripts/python/validation/confidence_remote.py",
          "terms": ["load_remote_route_contract", "validate_remote_route_target"]
        }
      ]
    },
    {
      "id": "remote-board-mode",
      "title": "Remote acceptance exposes board mode",
      "with_skill_expected_pass": true,
      "without_skill_expected_pass": false,
      "without_skill_reason": "Without the skill, there is no repo-local board-acceptance CLI contract.",
      "required_files": ["scripts/python/remote/remote_vitis_acceptance.py", "assets/validation-board/README.md"],
      "required_terms": [
        {
          "file": "scripts/python/remote/remote_vitis_acceptance.py",
          "terms": ["choices=(\"link\", \"pytest\", \"smoke\", \"vitis\", \"board\")", "HLS_BOARD_STATUS", "_run_board_mode"]
        }
      ]
    },
    {
      "id": "board-metadata-declarations",
      "title": "Shipped examples declare board acceptance",
      "with_skill_expected_pass": true,
      "without_skill_expected_pass": false,
      "without_skill_reason": "The baseline path does not inspect shipped example metadata contracts.",
      "required_files": [
        "assets/examples/hls_vector_scale_spec.json",
        "assets/examples/hls_task_graph_axis_spec.json",
        "assets/templates/hls_minimal_vitis_pipeline_template.json"
      ],
      "required_terms": [
        {
          "file": "assets/examples/hls_vector_scale_spec.json",
          "terms": ["\"board_acceptance\"", "\"u55c_m_axi_host\"", "\"vector_scale_host\""]
        },
        {
          "file": "assets/examples/hls_task_graph_axis_spec.json",
          "terms": ["\"board_acceptance\"", "\"not_board_runnable\""]
        },
        {
          "file": "assets/templates/hls_minimal_vitis_pipeline_template.json",
          "terms": ["\"board_acceptance\"", "\"u55c_m_axi_host\""]
        }
      ]
    },
    {
      "id": "typed-comment-policy-gate",
      "title": "Generated HLS comments use strict Chinese placement semantics",
      "with_skill_expected_pass": true,
      "without_skill_expected_pass": false,
      "without_skill_reason": "A baseline setup may check for comment presence without enforcing placement or hardware-intent semantics.",
      "required_files": [
        "runtime/hls_generator/comment_policy.py",
        "../../tests/test_comment_policy.py",
        "references/hls-comment-style.md",
        "../../tests/smoke/run_smoke.py"
      ],
      "required_terms": [
        {
          "file": "runtime/hls_generator/comment_policy.py",
          "terms": ["strict_chinese_hls_comment_spacing", "generic generated line", "PRAGMA_INTENT_KEYWORDS", "_GENERIC_COMMENT_PATTERNS"]
        },
        {
          "file": "../../tests/test_comment_policy.py",
          "terms": ["generic_and_misplaced_comments_are_blocking_errors", "uncommented_trivial_closing_lines"]
        },
        {
          "file": "references/hls-comment-style.md",
          "terms": ["strict Chinese comment placement", "Blocking examples", "Trivial lines"]
        },
        {
          "file": "../../tests/smoke/run_smoke.py",
          "terms": ["TUPLE_SMOKE_TEST_TARGETS", "test_comment_policy.py", "comment_policy"]
        }
      ]
    },
    {
      "id": "effect-eval-corpus",
      "title": "Skill repo ships an explicit evaluation corpus",
      "with_skill_expected_pass": true,
      "without_skill_expected_pass": false,
      "without_skill_reason": "A baseline setup does not ship repo-local eval cases.",
      "required_files": ["evals/evals.json", "scripts/python/evaluation/evaluate_skill.py"],
      "required_terms": [
        {
          "file": "evals/evals.json",
          "terms": ["Tool Wrapper", "Generator", "Reviewer", "Inversion", "Pipeline"]
        },
        {
          "file": "scripts/python/evaluation/evaluate_skill.py",
          "terms": ["pass_rate_delta", "with-skill", "without-skill"]
        }
      ]
    }
  ]
}
