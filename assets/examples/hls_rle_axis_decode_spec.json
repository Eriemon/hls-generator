{
  "name": "rle_axis_decode",
  "target": "hls",
  "design_requirements": {
    "target": "hls",
    "pipeline_required": true,
    "streamability": "streamable",
    "interface_family": "axi_stream",
    "interface_profile": {
      "keep_ready": true,
      "keep_last": true,
      "data_width": 32,
      "clock_reset_domain": {
        "clock": "ap_clk",
        "reset": "ap_rst_n"
      }
    },
    "confirmed_by_user": true,
    "confirmation_notes": "RLE AXIS decode frame and TLAST policy have been confirmed."
  },
  "streamability": "streamable",
  "interface_family": "axi_stream",
  "interface_profile": {
    "keep_ready": true,
    "keep_last": true,
    "data_width": 32,
    "clock_reset_domain": {
      "clock": "ap_clk",
      "reset": "ap_rst_n"
    }
  },
  "pipeline_required": true,
  "codegen_plan_required": true,
  "description": "Template for an AXI-Stream RLE decoder.",
  "interfaces": {
    "top_function": "rle_axis_decode_kernel",
    "arguments": [
      {
        "name": "in_stream",
        "type": "hls::stream<ap_axiu<16,0,0,0> >&",
        "direction": "input",
        "interface": "axis"
      },
      {
        "name": "out_stream",
        "type": "hls::stream<ap_axiu<8,0,0,0> >&",
        "direction": "output",
        "interface": "axis"
      },
      {
        "name": "length",
        "type": "int",
        "direction": "input",
        "interface": "s_axilite"
      }
    ],
    "control": "s_axilite"
  },
  "behavior": [
    "Preserve explicit AXIS boundary handling in comments and validation."
  ],
  "clock": {
    "period_ns": 8.0,
    "uncertainty_ns": 0.8
  },
  "reset": {
    "strategy": "tool_default"
  },
  "constraints": [
    "Keep run splitting and final-symbol framing explicit."
  ],
  "outputs": [
    {
      "path": "src/rle_axis_decode_kernel.h",
      "kind": "header",
      "language": "cpp"
    },
    {
      "path": "src/rle_axis_decode_kernel.cpp",
      "kind": "source",
      "language": "cpp"
    },
    {
      "path": "tb/rle_axis_decode_kernel_tb.cpp",
      "kind": "testbench",
      "language": "cpp"
    },
    {
      "path": "hls_config.cfg",
      "kind": "config",
      "language": "ini"
    }
  ],
  "notes": [],
  "subfunctions": [],
  "workflow": {
    "board_acceptance": {
      "profile": "not_board_runnable",
      "reason": "Curated template stays validation-focused and does not assume a board host harness."
    },
    "mock_vectors": [
      {
        "id": "case_nominal",
        "inputs": {
          "in_stream": [
            1,
            1,
            2
          ],
          "length": 3
        },
        "expected_outputs": {
          "out_stream": [
            2,
            2,
            3
          ]
        }
      },
      {
        "id": "case_boundary",
        "inputs": {
          "in_stream": [
            0,
            15
          ],
          "length": 2
        },
        "expected_outputs": {
          "out_stream": [
            1,
            16
          ]
        }
      }
    ]
  },
  "performance": {
    "target_ii": 1
  },
  "hls_profile": {
    "example_pattern": "rle_axis",
    "allowed_libraries": [
      "ap_int.h",
      "ap_axi_sdata.h",
      "hls_stream.h"
    ],
    "required_headers": [
      "ap_int.h",
      "ap_axi_sdata.h",
      "hls_stream.h"
    ],
    "required_pragmas": [
      "#pragma HLS PIPELINE II=1"
    ],
    "required_metadata_fields": [
      "frame_boundary_mode",
      "tlast_policy",
      "run_length_limit",
      "empty_frame_policy",
      "ii_target"
    ],
    "metadata": {
      "frame_boundary_mode": "tlast_terminated",
      "tlast_policy": "propagate_final_symbol",
      "run_length_limit": 255,
      "empty_frame_policy": "reject",
      "ii_target": 1
    },
    "forbidden_combinations": [],
    "required_cfg_entries": [
      "clock=8.0"
    ]
  }
}
