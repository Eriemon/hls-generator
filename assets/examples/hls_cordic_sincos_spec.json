{
  "name": "cordic_sincos",
  "target": "hls",
  "design_requirements": {
    "target": "hls",
    "pipeline_required": true,
    "streamability": "streamable",
    "interface_family": "axi4",
    "interface_profile": {
      "axi4_variant": "axi4_full",
      "role": "master",
      "read_write_mode": "read_write",
      "data_width": 32,
      "addr_width": 32,
      "id_width": 1,
      "burst_support": false,
      "clock_reset_domain": {
        "clock": "ap_clk",
        "reset": "ap_rst_n"
      }
    },
    "confirmed_by_user": true,
    "confirmation_notes": "CORDIC sin/cos generation has been confirmed."
  },
  "streamability": "streamable",
  "interface_family": "axi4",
  "interface_profile": {
    "axi4_variant": "axi4_full",
    "role": "master",
    "read_write_mode": "read_write",
    "data_width": 32,
    "addr_width": 32,
    "id_width": 1,
    "burst_support": false,
    "clock_reset_domain": {
      "clock": "ap_clk",
      "reset": "ap_rst_n"
    }
  },
  "pipeline_required": true,
  "codegen_plan_required": true,
  "description": "Template for a CORDIC sin/cos generator.",
  "interfaces": {
    "top_function": "cordic_sincos_kernel",
    "arguments": [
      {
        "name": "input",
        "type": "const ap_uint<32> *",
        "direction": "input",
        "interface": "m_axi",
        "bundle": "gmem0",
        "depth": 256
      },
      {
        "name": "output",
        "type": "ap_uint<32> *",
        "direction": "output",
        "interface": "m_axi",
        "bundle": "gmem1",
        "depth": 256
      },
      {
        "name": "length",
        "type": "int",
        "direction": "input",
        "interface": "s_axilite"
      }
    ],
    "control": "s_axilite"
  },
  "behavior": [
    "Keep tolerance-aware sin/cos comparison intent explicit."
  ],
  "clock": {
    "period_ns": 8.0,
    "uncertainty_ns": 0.8
  },
  "reset": {
    "strategy": "tool_default"
  },
  "constraints": [
    "Do not hide fixed-point format assumptions."
  ],
  "outputs": [
    {
      "path": "src/cordic_sincos_kernel.h",
      "kind": "header",
      "language": "cpp"
    },
    {
      "path": "src/cordic_sincos_kernel.cpp",
      "kind": "source",
      "language": "cpp"
    },
    {
      "path": "tb/cordic_sincos_kernel_tb.cpp",
      "kind": "testbench",
      "language": "cpp"
    },
    {
      "path": "hls_config.cfg",
      "kind": "config",
      "language": "ini"
    }
  ],
  "notes": [],
  "subfunctions": [],
  "workflow": {
    "board_acceptance": {
      "profile": "not_board_runnable",
      "reason": "Curated template stays validation-focused and does not assume a board host harness."
    },
    "mock_vectors": [
      {
        "id": "case_nominal",
        "inputs": {
          "input": [
            1,
            2,
            3,
            4
          ],
          "length": 4
        },
        "expected_outputs": {
          "output": [
            2,
            3,
            4,
            5
          ]
        }
      },
      {
        "id": "case_boundary",
        "inputs": {
          "input": [
            0,
            7
          ],
          "length": 2
        },
        "expected_outputs": {
          "output": [
            1,
            8
          ]
        }
      }
    ]
  },
  "performance": {
    "target_ii": 1
  },
  "hls_profile": {
    "example_pattern": "cordic",
    "allowed_libraries": [
      "ap_int.h",
      "ap_fixed.h"
    ],
    "required_headers": [
      "ap_int.h",
      "ap_fixed.h"
    ],
    "required_pragmas": [
      "#pragma HLS PIPELINE II=1"
    ],
    "required_metadata_fields": [
      "cordic_mode",
      "iteration_count",
      "angle_range",
      "fixed_point_format",
      "error_tolerance"
    ],
    "metadata": {
      "cordic_mode": "sincos",
      "iteration_count": 16,
      "angle_range": "[-pi, pi]",
      "fixed_point_format": "ap_fixed<24,4>",
      "error_tolerance": "0.004"
    },
    "forbidden_combinations": [],
    "required_cfg_entries": [
      "clock=8.0"
    ]
  }
}
