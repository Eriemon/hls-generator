    "confirmed_by_user": true,
    "confirmation_notes": "Board validation wraps the AXI-Stream RLE decoder behind memory-backed load/stream/drain boundaries."
  },
  "streamability": "streamable",
  "interface_family": "axi4",
  "interface_profile": {
    "axi4_variant": "axi4_full",
    "role": "master",
    "read_write_mode": "read_write",
    "data_width": 32,
    "addr_width": 32,
    "id_width": 1,
    "burst_support": false,
    "clock_reset_domain": {
      "clock": "ap_clk",
      "reset": "ap_rst_n"
    }
  },
  "pipeline_required": true,
  "codegen_plan_required": true,
  "description": "Board-runnable memory wrapper for the AXI-Stream RLE decoder family.",
  "interfaces": {
    "top_function": "rle_axis_decode_board_kernel",
    "arguments": [
      {
        "name": "input",
        "type": "const ap_uint<32> *",
        "direction": "input",
        "interface": "m_axi",
        "bundle": "gmem0",
        "depth": 256
      },
      {
        "name": "output",
        "type": "ap_uint<32> *",
        "direction": "output",
        "interface": "m_axi",
        "bundle": "gmem1",
        "depth": 256
      },
      {
        "name": "length",
        "type": "int",
        "direction": "input",
        "interface": "s_axilite"
      }
    ],
    "control": "s_axilite"
  },
  "behavior": [
    "Preserve TLAST, TKEEP, and TSTRB handling inside the wrapper so board validation still exercises the AXIS codec contract."
  ],
  "clock": {
    "period_ns": 8.0,
    "uncertainty_ns": 0.8
  },
  "reset": {
    "strategy": "tool_default"
  },
  "constraints": [
    "Keep the wrapper code visibly responsible for load, AXIS packetization, and memory drain boundaries."
  ],
  "outputs": [
    {
      "path": "src/rle_axis_decode_board_kernel.h",
      "kind": "header",
      "language": "cpp"
    },
    {
      "path": "src/rle_axis_decode_board_kernel.cpp",
      "kind": "source",
      "language": "cpp"
    },
    {
      "path": "tb/rle_axis_decode_board_kernel_tb.cpp",
      "kind": "testbench",
      "language": "cpp"
    },
    {
      "path": "hls_config.cfg",
      "kind": "config",
      "language": "ini"
    }
  ],
  "notes": [],
  "subfunctions": [],
  "workflow": {
    "board_acceptance": {
      "profile": "u55c_m_axi_host",
      "host_template": "wrapper_unary_memory_host",
      "source_spec": "hls_rle_axis_decode_spec.json",
      "target_family": "rle_axis"
    },
    "mock_vectors": [
      {
        "id": "case_nominal",
        "inputs": {
          "input": [
            1,
            1,
            2
          ],
          "length": 3
        },
        "expected_outputs": {
          "output": [
            2,
            2,
            3
          ]
        }
      },
      {
        "id": "case_boundary",
        "inputs": {
          "input": [
            0,
            15
          ],
          "length": 2
        },
        "expected_outputs": {
          "output": [
            1,
            16
          ]
        }
      }
    ]
  },
  "performance": {
    "target_ii": 1
  },
  "hls_profile": {
    "example_pattern": "rle_axis",
    "allowed_libraries": [
      "ap_int.h",
      "ap_axi_sdata.h",
      "hls_stream.h"
    ],
    "required_headers": [
      "ap_int.h",
      "ap_axi_sdata.h",
      "hls_stream.h"
    ],
    "required_pragmas": [
      "#pragma HLS PIPELINE II=1"
    ],
    "required_metadata_fields": [
      "frame_boundary_mode",
      "tlast_policy",
      "run_length_limit",
      "empty_frame_policy",
      "ii_target"
    ],
    "metadata": {
      "frame_boundary_mode": "tlast_terminated",
      "tlast_policy": "propagate_final_symbol",
      "run_length_limit": 255,
      "empty_frame_policy": "reject",
      "ii_target": 1
    },
    "forbidden_combinations": [],
    "required_cfg_entries": [
      "clock=8.0"
    ]
  }
